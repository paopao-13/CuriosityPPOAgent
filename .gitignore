# Python .gitignore

# ---- Python 字节码与缓存 ----
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# ---- 测试与覆盖率 ----
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# ---- 虚拟环境 ----
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ---- 分发包与构建 ----
*.egg-info/
*.egg
.eggs/
dist/
build/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.manifest
*.spec

# ---- 环境变量与密钥 ----
.env
.env.local
.env.*.local
*.pem
*.key

# ---- Jupyter Notebook 检查点 ----
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# ---- 类型检查与 lint 缓存 ----
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# ---- 实验追踪 ----
wandb/
wandb_debug/
mlruns/
mlartifacts/

# ---- 训练结果与模型权重 (大文件) ----
results/checkpoints/**/*.pt
results/checkpoints/**/*.pth
results/checkpoints/**/*.ckpt
results/onnx/**/*.onnx
results/videos/
results/logs/
results/ablation/
results/eval/
*.safetensors
*.pt
*.pth
*.ckpt
*.onnx

# ---- 日志文件 ----
*.log
logs/
*.log.*

# ---- PyTorch 缓存 ----
.torch/

# ---- 本地内部工作笔记（不纳入公开仓库，仅本地保留）----
notes/
docs/ATARI_POSTTRAIN_AND_ABLATION.md
docs/EXECUTION_PLAN.md
docs/KAGGLE_FREE_GPU.md
docs/VRAM_OPTIMIZATION.md
docs/WANDB_DASHBOARD.md
docs/release_note.md
GITHUB_PUSH_PREP.md


# ---- 压缩包 ----
*.tar.gz
*.tar
*.zip
*.gz
*.tgz
*.7z
*.rar

# ---- 操作系统 ----
.DS_Store
.DS_Store?
._*
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# ---- IDE 配置 ----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ---- Node.js / Web Demo ----
node_modules/
web/node_modules/
web/dist/
web/.vite/
web/.turbo/
web/stats.html
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ---- IGA Pages ----
.iga/

# ---- 其他 ----
*.bak
*.tmp
*.temp
.cache/
*.pid
*.seed
*.pid.lock

# ---- 本地私有/面试内容（绝不进公开仓库） ----
.workbuddy/
GITHUB_PUSH_PREP.md
